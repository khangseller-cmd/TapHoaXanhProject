@page
@model LogoutModel
@{
    ViewData["Title"] = "Đăng xuất";
}

<div class="row">
    <div class="col-md-6 mx-auto">
        <div class="card shadow-sm">
            <div class="card-header bg-danger text-white">
                <h4 class="mb-0"><i class="fas fa-sign-out-alt"></i> Đăng xuất</h4>
            </div>
            <div class="card-body text-center">
                <h5>Bạn có chắc muốn đăng xuất?</h5>
                <p class="text-muted">
                    Sau khi đăng xuất, bạn sẽ cần đăng nhập lại để truy cập tài khoản.
                </p>
                <form id="logoutForm" method="post">
                    <button type="submit" class="btn btn-danger btn-lg">
                        <i class="fas fa-sign-out-alt"></i> Đăng xuất
                    </button>
                </form>
                <hr />
                <a asp-page="./Login" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left"></i> Quay lại đăng nhập
                </a>
            </div>
        </div>
    </div>
</div>