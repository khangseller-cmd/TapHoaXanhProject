@page
@model NguyenDinhMinhKhang_2380600989.Areas.Identity.Pages.Account.ResetPasswordModel
@{
    ViewData["Title"] = "Đặt lại mật khẩu";
}

<div class="row">
    <div class="col-md-6 mx-auto">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0"><i class="fas fa-lock"></i> Đặt lại mật khẩu</h4>
            </div>
            <div class="card-body">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success">
                        @TempData["Success"]
                    </div>
                }

                <h5>Nhập mã OTP và mật khẩu mới</h5>
                <hr />
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <input type="hidden" asp-for="Input.Email" />

                    <div class="mb-3">
                        <label asp-for="Input.Code" class="form-label">Mã OTP</label>
                        <input asp-for="Input.Code" class="form-control" placeholder="123456" maxlength="6" />
                        <span asp-validation-for="Input.Code" class="text-danger"></span>
                        <small class="text-muted">Mã có hiệu lực trong 15 phút</small>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.Password" class="form-label">Mật khẩu mới</label>
                        <input asp-for="Input.Password" class="form-control" type="password" />
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.ConfirmPassword" class="form-label">Xác nhận mật khẩu</label>
                        <input asp-for="Input.ConfirmPassword" class="form-control" type="password" />
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">
                        <i class="fas fa-check"></i> Đặt lại mật khẩu
                    </button>
                </form>
                <div class="mt-3 text-center">
                    <a asp-page="./ForgotPassword">Gửi lại mã OTP</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}