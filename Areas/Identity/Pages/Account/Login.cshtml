@page
@model LoginModel
@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="row">
    <div class="col-md-6 mx-auto">
        <div class="card shadow-sm">
            <div class="card-header bg-success text-white">
                <h4 class="mb-0"><i class="fas fa-sign-in-alt"></i> Đăng nhập</h4>
            </div>
            <div class="card-body">

                @* ===== PHẦN 1: ĐĂNG NHẬP BẰNG GOOGLE (FORM RIÊNG) ===== *@
                @if ((Model.ExternalLogins?.Count ?? 0) > 0)
                {
                    <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="mb-3">
                        <div class="d-grid gap-2">
                            @foreach (var provider in Model.ExternalLogins!)
                            {
                                <button type="submit" class="btn btn-danger btn-lg" name="provider" value="@provider.Name">
                                    <i class="fab fa-google me-2"></i> Đăng nhập bằng @provider.DisplayName
                                </button>
                            }
                        </div>
                    </form>

                    <div class="text-center mb-3">
                        <span class="text-muted">── hoặc đăng nhập bằng email ──</span>
                    </div>
                }

                @* ===== PHẦN 2: ĐĂNG NHẬP BẰNG EMAIL/PASSWORD ===== *@
                <form id="account" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Input.Email" class="form-label fw-bold">Email</label>
                        <input asp-for="Input.Email" class="form-control" placeholder="your@email.com" autocomplete="username" />
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.Password" class="form-label fw-bold">Mật khẩu</label>
                        <input asp-for="Input.Password" class="form-control" type="password" autocomplete="current-password" />
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="form-check">
                                <input asp-for="Input.RememberMe" class="form-check-input" />
                                <label asp-for="Input.RememberMe" class="form-check-label">
                                    Ghi nhớ đăng nhập
                                </label>
                            </div>
                            <a asp-page="./ForgotPassword" class="text-decoration-none small">
                                <i class="fas fa-key"></i> Quên mật khẩu?
                            </a>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-success w-100 btn-lg">
                        <i class="fas fa-sign-in-alt"></i> Đăng nhập
                    </button>
                </form>

                <hr />

                <div class="text-center">
                    <p>
                        Chưa có tài khoản?
                        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="text-success fw-bold">
                            Đăng ký ngay
                        </a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}