@model IEnumerable<NguyenDinhMinhKhang_2380600989.Models.Product>
@{
    ViewData["Title"] = "Quản lý sản phẩm";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-success">
        <i class="fas fa-box"></i> Quản lý sản phẩm
    </h2>
    <a asp-action="Create" class="btn btn-success">
        <i class="fas fa-plus"></i> Thêm sản phẩm mới
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead class="table-success">
                    <tr>
                        <th>Ảnh</th>
                        <th>Tên sản phẩm</th>
                        <th>Danh mục</th>
                        <th>Giá</th>
                        <th>Tồn kho</th>
                        <th>Ngày tạo</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <img src="@(item.MainImage ?? "https://via.placeholder.com/60x60")"
                                     style="width: 60px; height: 60px; object-fit: cover; border-radius: 8px;" />
                            </td>
                            <td>
                                <strong>@item.Name</strong>
                                <br><small class="text-muted">@item.Slug</small>
                            </td>
                            <td>@item.Category?.Name</td>
                            <td class="text-success fw-bold">
                                @item.Price.ToString("N0", new System.Globalization.CultureInfo("vi-VN")) đ
                            </td>
                            <td>
                                @if (item.StockQuantity < 10)
                                {
                                    <span class="badge bg-danger">@item.StockQuantity</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">@item.StockQuantity</span>
                                }
                            </td>
                            <td>@item.CreatedAt.ToString("dd/MM/yyyy")</td>
                            <td>
                                <div class="btn-group">
                                    @if (ViewBag.IsAdmin)
                                    {
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">
                                            <i class="fas fa-edit"></i> Sửa
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">
                                            <i class="fas fa-trash"></i> Xóa
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Chỉ xem</span>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>