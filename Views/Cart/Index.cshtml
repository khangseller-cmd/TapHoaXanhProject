@model NguyenDinhMinhKhang_2380600989.Models.Cart
@{
    ViewData["Title"] = "Giỏ hàng";
}

<h2 class="fw-bold text-success mb-4">
    <i class="fas fa-shopping-cart"></i> Giỏ hàng của bạn
</h2>

@if (Model != null && Model.CartItems != null && Model.CartItems.Any())
{
    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead class="table-success">
                        <tr>
                            <th>Sản phẩm</th>
                            <th>Giá</th>
                            <th>Số lượng</th>
                            <th>Thành tiền</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.CartItems)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <img src="@(item.Product?.MainImage ?? "https://via.placeholder.com/60x60")"
                                             style="width: 60px; height: 60px; object-fit: cover; border-radius: 8px; margin-right: 15px;" />
                                        <div>
                                            <strong>@item.Product?.Name</strong>
                                            <br><small class="text-muted">@item.Product?.Category?.Name</small>
                                        </div>
                                    </div>
                                </td>
                                <td class="text-success fw-bold">
                                    @item.Product?.Price.ToString("N0", new System.Globalization.CultureInfo("vi-VN")) đ
                                </td>
                                <td>
                                    <span class="badge bg-secondary">@item.Quantity</span>
                                </td>
                                <td class="fw-bold">
                                    @((item.Product!.Price * item.Quantity).ToString("N0", new System.Globalization.CultureInfo("vi-VN"))) đ
                                </td>
                                <td>
                                    <form asp-action="RemoveFromCart" method="post">
                                        <input type="hidden" name="cartItemId" value="@item.Id" />
                                        <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Bạn có chắc muốn xóa?')">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-success">
                        <tr>
                            <th colspan="3" class="text-end">Tổng cộng:</th>
                            <th class="fs-5 text-success">
                                @Model.CartItems.Sum(i => i.Product!.Price * i.Quantity).ToString("N0", new System.Globalization.CultureInfo("vi-VN")) đ
                            </th>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>
            </div>

            <div class="d-flex justify-content-between mt-4">
                <a asp-controller="Home" asp-action="Products" class="btn btn-outline-success">
                    <i class="fas fa-arrow-left"></i> Tiếp tục mua sắm
                </a>
                <form asp-controller="Cart" asp-action="Checkout" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-success btn-lg">
                        <i class="fas fa-credit-card"></i> Thanh toán
                    </button>
                </form>
            </div>
        </div>
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body text-center py-5">
            <i class="fas fa-shopping-cart fa-5x text-muted mb-3"></i>
            <h4>Giỏ hàng của bạn đang trống</h4>
            <p class="text-muted">Hãy thêm sản phẩm vào giỏ hàng để tiếp tục mua sắm</p>
            <a asp-controller="Home" asp-action="Products" class="btn btn-success btn-lg">
                <i class="fas fa-shopping-basket"></i> Mua sắm ngay
            </a>
        </div>
    </div>
}