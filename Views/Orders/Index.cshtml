@model IEnumerable<NguyenDinhMinhKhang_2380600989.Models.Order>
@{
    ViewData["Title"] = ViewBag.IsAdmin ? "Quản lý đơn hàng" : "Đơn hàng của tôi";
    var isAdmin = ViewBag.IsAdmin as bool? ?? false;
}

<h2 class="fw-bold text-success mb-4">
    <i class="fas fa-receipt"></i> @(isAdmin ? "Quản lý đơn hàng" : "Đơn hàng của tôi")
</h2>

@if (Model.Any())
{
    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead class="table-success">
                        <tr>
                            <th>Mã đơn</th>
                            @if (isAdmin)
                            {
                                <th>Khách hàng</th>
                            }
                            <th>Ngày đặt</th>
                            <th>Tổng tiền</th>
                            <th>Trạng thái</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model)
                        {
                            <tr>
                                <td><strong>#@order.Id</strong></td>
                                @if (isAdmin)
                                {
                                    <td>@order.ReceiverName</td>
                                }
                                <td>@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="text-success fw-bold">
                                    @order.TotalAmount.ToString("N0", new System.Globalization.CultureInfo("vi-VN")) đ
                                </td>
                                <td>
                                    @switch (order.Status)
                                    {
                                        case NguyenDinhMinhKhang_2380600989.Models.OrderStatus.Pending:
                                            <span class="badge bg-warning text-dark">Chờ xác nhận</span>
                                            break;
                                        case NguyenDinhMinhKhang_2380600989.Models.OrderStatus.Confirmed:
                                            <span class="badge bg-info text-dark">Đã xác nhận</span>
                                            break;
                                        case NguyenDinhMinhKhang_2380600989.Models.OrderStatus.Processing:
                                            <span class="badge bg-primary">Đang xử lý</span>
                                            break;
                                        case NguyenDinhMinhKhang_2380600989.Models.OrderStatus.Shipping:
                                            <span class="badge bg-primary">Đang giao</span>
                                            break;
                                        case NguyenDinhMinhKhang_2380600989.Models.OrderStatus.Completed:
                                            <span class="badge bg-success">Hoàn thành</span>
                                            break;
                                        case NguyenDinhMinhKhang_2380600989.Models.OrderStatus.Cancelled:
                                            <span class="badge bg-danger">Đã hủy</span>
                                            break;
                                    }
                                </td>
                                <td>
                                    <div class="btn-group">
                                        <a asp-action="Detail" asp-route-id="@order.Id" class="btn btn-sm btn-primary">
                                            <i class="fas fa-eye"></i> Xem
                                        </a>
                                        @if (isAdmin && order.Status != NguyenDinhMinhKhang_2380600989.Models.OrderStatus.Completed && order.Status != NguyenDinhMinhKhang_2380600989.Models.OrderStatus.Cancelled)
                                        {
                                            <form asp-action="UpdateStatus" method="post" class="d-inline">
                                                <input type="hidden" name="id" value="@order.Id" />
                                                <select name="status" class="form-select form-select-sm d-inline-block" style="width: auto;">
                                                    <option value="Pending">Chờ xác nhận</option>
                                                    <option value="Confirmed">Đã xác nhận</option>
                                                    <option value="Processing">Đang xử lý</option>
                                                    <option value="Shipping">Đang giao</option>
                                                    <option value="Completed">Hoàn thành</option>
                                                    <option value="Cancelled">Hủy</option>
                                                </select>
                                                <button type="submit" class="btn btn-sm btn-success">
                                                    <i class="fas fa-save"></i>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body text-center py-5">
            <i class="fas fa-receipt fa-5x text-muted mb-3"></i>
            <h4>Chưa có đơn hàng nào</h4>
            <p class="text-muted">Hãy mua sắm để tạo đơn hàng đầu tiên</p>
            <a asp-controller="Home" asp-action="Products" class="btn btn-success btn-lg">
                <i class="fas fa-shopping-basket"></i> Mua sắm ngay
            </a>
        </div>
    </div>
}