@model NguyenDinhMinhKhang_2380600989.Models.Product
@{
    ViewData["Title"] = Model.Name;
    var relatedProducts = ViewBag.RelatedProducts as List<NguyenDinhMinhKhang_2380600989.Models.Product>;
}

<!-- Product Detail -->
<div class="card shadow-sm mb-4">
    <div class="card-body">
        <div class="row">
            <div class="col-md-6">
                <!-- Main Image -->
                <img src="@(Model.MainImage ?? "https://via.placeholder.com/500x500/2ecc71/ffffff?text=San+pham")"
                     class="img-fluid rounded mb-3" alt="@Model.Name" style="max-height: 500px; width: 100%; object-fit: cover;">

                <!-- Product Images -->
                @if (Model.ProductImages != null && Model.ProductImages.Any())
                {
                    <div class="row g-2">
                        @foreach (var img in Model.ProductImages.OrderBy(i => i.DisplayOrder))
                        {
                            <div class="col-3">
                                <img src="@img.ImageUrl" class="img-fluid rounded" style="cursor: pointer;"
                                     onclick="document.getElementById('mainImage').src='@img.ImageUrl'" />
                            </div>
                        }
                    </div>
                }

                <!-- Video -->
                @if (!string.IsNullOrEmpty(Model.VideoUrl))
                {
                    <div class="mt-4">
                        <h5 class="fw-bold"><i class="fas fa-video"></i> Video giới thiệu</h5>
                        <div class="ratio ratio-16x9">
                            <iframe src="@Model.VideoUrl" frameborder="0" allowfullscreen></iframe>
                        </div>
                    </div>
                }
            </div>

            <div class="col-md-6">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a asp-action="Index">Trang chủ</a></li>
                        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Products">Sản phẩm</a></li>
                        <li class="breadcrumb-item active">@Model.Category?.Name</li>
                    </ol>
                </nav>

                <h1 class="fw-bold mb-3">@Model.Name</h1>

                <div class="mb-3">
                    <span class="badge bg-success">@Model.Category?.Name</span>
                    <span class="text-muted ms-2"><i class="fas fa-box"></i> Còn: @Model.StockQuantity sản phẩm</span>
                </div>

                <div class="mb-4">
                    <span class="fs-2 fw-bold text-success">
                        @Model.Price.ToString("N0", new System.Globalization.CultureInfo("vi-VN")) đ
                    </span>
                </div>

                <div class="mb-4">
                    <h5 class="fw-bold">Mô tả sản phẩm</h5>
                    <p class="text-muted">@Model.Description</p>
                </div>

                @if (User.Identity!.IsAuthenticated)
                {
                    @if (Model.StockQuantity > 0)
                    {
                        <form asp-controller="Cart" asp-action="AddToCart" method="post">
                            <input type="hidden" name="productId" value="@Model.Id" />
                            <button type="submit" class="btn btn-success btn-lg w-100">
                                <i class="fas fa-cart-plus"></i> Thêm vào giỏ hàng
                            </button>
                        </form>
                    }
                    else
                    {
                        <button class="btn btn-secondary btn-lg w-100" disabled>
                            <i class="fas fa-ban"></i> Hết hàng
                        </button>
                    }
                }
                else
                {
                    <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-outline-success btn-lg w-100">
                        <i class="fas fa-sign-in-alt"></i> Đăng nhập để mua
                    </a>
                }

                <div class="mt-4 p-3 bg-light rounded">
                    <h6 class="fw-bold"><i class="fas fa-truck"></i> Giao hàng</h6>
                    <p class="mb-1">✓ Giao hàng trong 2 giờ nội thành</p>
                    <p class="mb-1">✓ Miễn phí giao hàng cho đơn từ 500.000đ</p>
                    <p class="mb-0">✓ Đổi trả trong 7 ngày</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Related Products -->
@if (relatedProducts != null && relatedProducts.Any())
{
    <h3 class="fw-bold text-success mb-4">
        <i class="fas fa-th"></i> Sản phẩm liên quan
    </h3>
    <div class="product-grid">
        @foreach (var product in relatedProducts)
        {
            <div class="product-card">
                <div class="product-image-wrapper">
                    <img src="@(product.MainImage ?? "https://via.placeholder.com/300x300")" alt="@product.Name">
                </div>
                <div class="product-info">
                    <h5 class="product-name">@product.Name</h5>
                    <div class="product-price">
                        <span class="price-current">@product.Price.ToString("N0", new System.Globalization.CultureInfo("vi-VN"))</span>
                        <span class="price-unit">đ</span>
                    </div>
                    <a asp-controller="Home" asp-action="Detail"
                       asp-route-id="@product.Id"
                       asp-route-slug="@product.Slug" class="btn-add-cart">
                        Xem chi tiết
                    </a>
                </div>
            </div>
        }
    </div>
}