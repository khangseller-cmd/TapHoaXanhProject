@{
    ViewData["Title"] = "Admin Dashboard";
    var totalProducts = (int)ViewBag.TotalProducts;
    var totalOrders = (int)ViewBag.TotalOrders;
    var totalUsers = (int)ViewBag.TotalUsers;
    var totalRevenue = (decimal)ViewBag.TotalRevenue;
    var recentOrders = ViewBag.RecentOrders as List<NguyenDinhMinhKhang_2380600989.Models.Order>;
    var lowStockProducts = ViewBag.LowStockProducts as List<NguyenDinhMinhKhang_2380600989.Models.Product>;
}

<h2 class="fw-bold text-success mb-4">
    <i class="fas fa-tachometer-alt"></i> Bảng điều khiển Admin
</h2>

<!-- Thống kê - CÓ THỂ CLICK -->
<div class="row mb-4">
    <div class="col-md-3">
        <a asp-controller="Products" asp-action="Index" class="text-decoration-none">
            <div class="card bg-success text-white shadow-sm h-100 hover-card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="mb-1">Tổng sản phẩm</h6>
                            <h2 class="fw-bold mb-0">@totalProducts</h2>
                        </div>
                        <i class="fas fa-box fa-2x opacity-50"></i>
                    </div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-3">
        <a asp-controller="Orders" asp-action="Index" class="text-decoration-none">
            <div class="card bg-primary text-white shadow-sm h-100 hover-card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="mb-1">Tổng đơn hàng</h6>
                            <h2 class="fw-bold mb-0">@totalOrders</h2>
                        </div>
                        <i class="fas fa-shopping-cart fa-2x opacity-50"></i>
                    </div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-3">
        <a asp-controller="Admin" asp-action="Users" class="text-decoration-none">
            <div class="card bg-info text-white shadow-sm h-100 hover-card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="mb-1">Tổng người dùng</h6>
                            <h2 class="fw-bold mb-0">@totalUsers</h2>
                        </div>
                        <i class="fas fa-users fa-2x opacity-50"></i>
                    </div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-3">
        <a asp-controller="Admin" asp-action="Statistics" class="text-decoration-none">
            <div class="card bg-warning text-dark shadow-sm h-100 hover-card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="mb-1">Doanh thu</h6>
                            <h2 class="fw-bold mb-0">@totalRevenue.ToString("N0") đ</h2>
                        </div>
                        <i class="fas fa-dollar-sign fa-2x opacity-50"></i>
                    </div>
                </div>
            </div>
        </a>
    </div>
</div>

<div class="row">
    <!-- Đơn hàng gần đây -->
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="fas fa-receipt"></i> Đơn hàng gần đây</h5>
                <a asp-controller="Orders" asp-action="Index" class="btn btn-sm btn-light">
                    Xem tất cả <i class="fas fa-arrow-right"></i>
                </a>
            </div>
            <div class="card-body">
                @if (recentOrders != null && recentOrders.Any())
                {
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Mã đơn</th>
                                <th>Ngày</th>
                                <th>Tổng tiền</th>
                                <th>Trạng thái</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in recentOrders)
                            {
                                <tr style="cursor: pointer;" onclick="window.location.href='/Orders/Detail/@order.Id'">
                                    <td><strong>#@order.Id</strong></td>
                                    <td>@order.OrderDate.ToString("dd/MM/yyyy")</td>
                                    <td>@order.TotalAmount.ToString("N0") đ</td>
                                    <td>
                                        @switch (order.Status)
                                        {
                                            case NguyenDinhMinhKhang_2380600989.Models.OrderStatus.Pending:
                                                <span class="badge bg-warning text-dark">Chờ xác nhận</span>
                                                break;
                                            case NguyenDinhMinhKhang_2380600989.Models.OrderStatus.Confirmed:

                                                <span class="badge bg-info text-dark">Đã xác nhận</span>
                                                break;
                                            case NguyenDinhMinhKhang_2380600989.Models.OrderStatus.Processing:

                                                <span class="badge bg-primary">Đang xử lý</span>
                                                break;
                                            case NguyenDinhMinhKhang_2380600989.Models.OrderStatus.Shipping:

                                                <span class="badge bg-primary">Đang giao</span>
                                                break;
                                            case NguyenDinhMinhKhang_2380600989.Models.OrderStatus.Completed:

                                                <span class="badge bg-success">Hoàn thành</span>
                                                break;
                                            case NguyenDinhMinhKhang_2380600989.Models.OrderStatus.Cancelled:

                                                <span class="badge bg-danger">Đã hủy</span>
                                                break;
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted text-center py-3">Chưa có đơn hàng nào</p>
                }
            </div>
        </div>
    </div>

    <!-- Sản phẩm sắp hết hàng -->
    <div class="col-md-4">
        <div class="card shadow-sm border-warning">
            <div class="card-header bg-warning text-dark">
                <h5 class="mb-0"><i class="fas fa-exclamation-triangle"></i> Sắp hết hàng</h5>
            </div>
            <div class="card-body">
                @if (lowStockProducts != null && lowStockProducts.Any())
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var product in lowStockProducts)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center" style="cursor: pointer;" onclick="window.location.href='/Products/Edit/@product.Id'">
                                <span>@product.Name</span>
                                <span class="badge bg-danger rounded-pill">@product.StockQuantity</span>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-muted text-center">Tất cả sản phẩm còn đủ hàng!</p>
                }
            </div>
        </div>
    </div>
</div>

<style>
    .hover-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .hover-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 25px rgba(0,0,0,0.15) !important;
        }
</style>